# ─────────────────────────────────────────────────────────────
# Language School Landing Page — Environment Variables
#
# 1. Copy this file:  cp .env.example .env.local
# 2. Fill in the values below
# 3. NEVER commit .env.local to version control
# ─────────────────────────────────────────────────────────────

# ── Site ─────────────────────────────────────────────────────
# Public URL of your deployment (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# School / brand name displayed across the UI (titles, metadata, footer)
NEXT_PUBLIC_SCHOOL_NAME=Language School

# ── WhatsApp ─────────────────────────────────────────────────
# Business number — country code + area code + number
# No +, no spaces, no dashes. Brazil example: 5521999990000
NEXT_PUBLIC_WHATSAPP_NUMBER=5500000000000

# ── Contact ──────────────────────────────────────────────────
# Formatted phone number shown in UI  (e.g. "+55 21 99999-0000")
NEXT_PUBLIC_CONTACT_PHONE=+00 00 00000-0000

# Contact email displayed on the site
NEXT_PUBLIC_CONTACT_EMAIL=hello@your-domain.com

# Instagram profile URL and handle
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/your_handle
NEXT_PUBLIC_INSTAGRAM_HANDLE=@your_handle

# ── E-commerce ───────────────────────────────────────────────
# Checkout / payment link for the first material product
NEXT_PUBLIC_CHECKOUT_URL=https://your-checkout-provider.com/product-slug

# ── Analytics ────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (optional — leave empty to disable)
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=
