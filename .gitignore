# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — .env.local and .env stay secret, .env.example is committed
.env.local
.env.development.local
.env.test.local
.env.production.local
.env

# private business assets — never commit client photos, logos, or materials
/private-assets
/private-content
/public/private

# real brand logos (replace with your own in public/)
/public/logo-schillings*.png
/public/logo-schillings*.jpg

# real photos — client content, not part of the template
/public/hero-*.jpg
/public/hero-*.png
/public/offshore-*.jpg
/public/program-*.jpg
/public/capa-*.png

# exports, backups, local data
*.export
*.backup
/exports
/backups
/data-local

# editor / OS
.DS_Store
Thumbs.db

# vercel
.vercel

# typescript build artifacts
*.tsbuildinfo
next-env.d.ts

# AI tooling — never expose agent config, memory, or prompts
CLAUDE.md
AGENTS.md
CONTEXT.md
.claude
.claude/
.cursor/
.cursor_rules
.aider*
.copilot/
*.claude
*.prompt
*.system-prompt

# Prompt and context directories
/prompts
/prompt
/context
/ai-context
/llm-context
/PROJECT_CONTEXT
/CONTENT
/REFERENCES
/SKILLS
/UX
/FUNNELS
/SEO
/TECH
/ASSETS
/private
